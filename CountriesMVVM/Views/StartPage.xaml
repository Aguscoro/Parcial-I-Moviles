<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CountriesMVVM.ViewModels"
             x:Class="CountriesMVVM.Views.StartPage">

    <ContentPage.BindingContext>
        <viewmodels:StartViewModel />
    </ContentPage.BindingContext>

    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="18" Padding="28">
        <Label Text="Paises del mundo"
               FontSize="34"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="{StaticResource TextPrimary}"/>

        <Label Text="Explora capitales y monedas"
               FontSize="14"
               TextColor="{StaticResource TextSecondary}"
               HorizontalOptions="Center"/>

        <!-- Boton para cargar -->
        <Button Text="Cargar paises"
                Command="{Binding IrAPaisesCommand}"
                WidthRequest="220"/>
    </VerticalStackLayout>
</ContentPage>

